# ─── Database ─────────────────────────────────────────────────────────────────
# Options: postgresql | mysql | sqlite
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://hop_user:hop_password@localhost:5432/hop_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-at-least-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-me-to-32-char-hex-string!!

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Superadmin Seed ──────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FIRSTNAME=Super
SEED_ADMIN_LASTNAME=Admin

# ─── Currency / Exchange Rates ────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=
DEFAULT_CURRENCY=USD

# ─── Plugin Trust Levels ──────────────────────────────────────────────────────
# Options: trusted | sandboxed
DEFAULT_PLUGIN_TRUST_LEVEL=sandboxed
